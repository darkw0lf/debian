# /etc/suricata/rules/local.rules

# Règle 1 : Détection scan NMAP SYN
alert tcp $EXTERNAL_NET any -> $HOME_NET any (
  msg:"SCAN NMAP SYN Scan Detected";
  flags:S,12;
  threshold: type threshold, track by_src, count 10, seconds 1;
  classtype:network-scan;
  sid:9000001; rev:1;)

# Règle 2 : Tentative connexion SSH
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (
  msg:"SSH Connection Attempt from External";
  flow:to_server,established;
  content:"SSH-";
  depth:4;
  classtype:attempted-admin;
  sid:9000002; rev:1;)

# Règle 3 : Mot de passe FTP en clair
alert tcp any any -> $HOME_NET 21 (
  msg:"FTP Clear-Text Password Detected";
  flow:to_server,established;
  content:"PASS "; nocase;
  classtype:policy-violation;
  sid:9000003; rev:1;)
